# 本機開發用 SQLite；部署時改 Postgres
DATABASE_URL="file:./dev.db"

# NextAuth
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="http://localhost:3002"
AUTH_TRUST_HOST="true"
# 備援（NextAuth v5 自動讀 AUTH_* 但這兩個也寫一份）
NEXTAUTH_SECRET="same-as-AUTH_SECRET"
NEXTAUTH_URL="http://localhost:3002"

# Google OAuth（去 Google Cloud Console 建）
# 已授權的重新導向 URI: http://localhost:3002/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 允許登入的 email（逗號分隔）
ALLOWED_EMAILS="amyclaw4928@gmail.com"

# Replicate API（等要實際辨識時再去 https://replicate.com 拿）
REPLICATE_API_TOKEN=""
